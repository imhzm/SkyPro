# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Database Configuration
DB_HOST=127.0.0.1
DB_NAME=senderpro
DB_USER=senderpro_user
DB_PASS=replace_with_strong_database_password

# JWT Secret (MUST be changed to a secure random string, min 32 chars)
# Generate one with: openssl rand -hex 32
JWT_SECRET=replace_with_64_char_hex_random_string_here_change_this_now

# Application URL (used for CORS whitelist)
APP_URL=https://your-domain.example

# Allowed Origins (comma-separated, for CORS)
# Add your Electron app's domains here. Use * for development only.
ALLOWED_ORIGINS=https://your-domain.example
ALLOW_NULL_ORIGIN=false
TRUST_PROXY_HEADERS=false

# Admin-only key generation endpoint
# Generate one with: openssl rand -hex 32
ADMIN_API_KEY=replace_with_64_char_hex_random_string_here

# Environment (production, development)
APP_ENV=production
