ell(value)).join(','), ...lines]\n      .join('\\n')\n\n    const blob = new Blob([`\\uFEFF${csvContent}`], {\n      type: 'text/csv;charset=utf-8;',\n    })\n    const url = URL.createObjectURL(blob)\n    const anchor = document.createElement('a')\n    anchor.href = url\n    anchor.download = `leads-${activePlatform.id}.csv`\n    anchor.click()\n    URL.revokeObjectURL(url)\n    setImportNotice({\n      tone: 'success',\n      message: `تم تصدير ${activeLeads.length} سجل من منصة ${activePlatform.name}.`,\n    })\n  }\n\n  async function exportLeadsAsExcel() {\n    const xlsx = await loadXlsx()\n    const worksheetRows = activeLeads.map((lead) => ({\n      'الاسم الكامل': lead.fullName,\n      الشركة: lead.company,\n      الهاتف: lead.phone,\n      'البريد الإلكتروني': lead.email,\n      المصدر: lead.source,\n      الحالة: lead.status,\n      الأولوية: lead.priority,\n      الملاحظات: lead.notes,\n      'تاريخ الإنشاء': lead.createdAt,\n    }))\n    const worksheet = xlsx.utils.json_to_sheet(worksheetRows)\n    const workbook = xlsx.utils.book_new()\n    xlsx.utils.book_append_sheet(workbook, worksheet, 'Leads')\n    await downloadWorkbook(workbook, `leads-${activePlatform.id}.xlsx`)\n    setImportNotice({\n      tone: 'success',\n      message: `تم تصدير ${activeLeads.length} سجل Excel من منصة ${activePlatform.name}.`,\n    })\n  }\n\n  async function exportAnalyticsReport() {\n    const xlsx = await loadXlsx()\n    const overviewSheet = xlsx.utils.json_to_sheet([\n      { المؤشر: 'إجمالي السجلات', القيمة: leads.length },\n      { المؤشر: 'الحملات الجاهزة أو النشطة', القيمة: readyCampaignsCount },\n    ])\n\n    const platformsSheet = xlsx.utils.json_to_sheet(\n      platformAnalytics.map((platform) => ({\n        المنصة: platform.name,\n        السجلات: platform.leadCount,\n        الحملات: platform.campaignCount,\n        الحسابات: platform.accountCount,\n        النقاط: platform.score,\n      })),\n    )\n\n\n\n    const workbook = xlsx.utils.book_new()\n    xlsx.utils.book_append_sheet(workbook, overviewSheet, 'Overview')\n    xlsx.utils.book_append_sheet(workbook, platformsSheet, 'Platforms')\n    await downloadWorkbook(workbook, 'sender-pro-analytics-report.xlsx')\n    setImportNotice({\n      tone: 'success',\n      message: 'تم إنشاء تقرير التحليلات بصيغة Excel بنجاح.',\n    })\n  }\n\n  async function handleImportFile(event: ChangeEvent\u003cHTMLInputElement>) {\n    const file = event.target.files?.[0]\n    if (!file) return\n\n    try {\n      const fileName = file.name.toLowerCase()\n      let rows: string[][] = []\n\n      if (fileName.endsWith('.csv')) {\n        const rawText = await file.text()\n        rows = rawText\n          .replace(/^\\uFEFF/, '')\n          .split(/\\r?\\n/)\n          .map((line) => line.trim())\n          .filter(Boolean)\n          .map((row) => parseCsvLine(row))\n      } else {\n        const xlsx = await loadXlsx()\n        const buffer = await file.arrayBuffer()\n        const workbook = xlsx.read(buffer, { type: 'array' })\n        const worksheet = workbook.Sheets[workbook.SheetNames[0]]\n        rows = (xlsx.utils.sheet_to_json(worksheet, {\n          header: 1,\n          defval: '',\n        }) as Array\u003cArray\u003cstring | number>>).map((row) => row.map((cell) => String(cell).trim()))\n      }\n\n      const dataRows = rows.slice(1).filter((row) => row.some((cell) => cell))\n\n      if (dataRows.length === 0) {\n        setImportNotice({\n          tone: 'error',\n          message: 'الملف لا يحتوي على بيانات كافية للاستيراد.',\n        })\n        return\n      }\n\n      const importedLeads = dataRows.map((columns) =>\n        buildLeadRecordFromColumns(columns, activePlatform.id, activePlatform.name),\n      )\n\n      setLeads((current) => [...importedLeads, ...current])\n      setImportNotice({\n        tone: 'success',\n        message: `تم استيراد ${importedLeads.length} سجل إلى منصة ${activePlatform.name} من ملف ${\n          fileName.endsWith('.csv') ? 'CSV' : 'Excel'\n        }.`,\n      })\n    } catch {\n      setImportNotice({\n        tone: 'error',\n        message: 'حدثت مشكلة أثناء قراءة ملف CSV أو Excel. تأكد من تنسيق الملف وحاول مرة أخرى.',\n      })\n    } finally {\n      event.target.value = ''\n    }\n  }\n\n  return (\n    \u003cdiv className=\"app-shell\" dir=\"rtl\">\n      \u003caside className=\"sidebar\">\n        \u003cdiv className=\"sidebar-brand\">\n          \u003cdiv className=\"sidebar-logo\">SP\u003c/div>\n          \u003cdiv>\n            \u003cstrong>سيندر برو\u003c/strong>\n            \u003cspan>منصة ديسكتوب تسويقية\u003c/span>\n          \u003c/div>\n        \u003c/div>\n\n        \u003cdiv className=\"sidebar-group\">\n          \u003cspan className=\"sidebar-group__title\">التنقل الرئيسي\u003c/span>\n          \u003cdiv className=\"sidebar-nav\">\n            {navigationItems.map(({ id, label, description, icon: Icon }) => (\n              \u003cbutton\n                key={id}\n                className={activeView === id ? 'sidebar-link active' : 'sidebar-link'}\n                onClick={() => setActiveView(id)}\n                type=\"button\"\n              >\n                \u003cspan className=\"sidebar-link__icon\">\n                  \u003cIcon size={18} />\n                \u003c/span>\n                \u003cspan>\n                  \u003cstrong>{label}\u003c/strong>\n                  \u003csmall>{description}\u003c/small>\n                \u003c/span>\n              \u003c/button>\n            ))}\n          \u003c/div>\n        \u003c/div>\n\n        \u003cdiv className=\"sidebar-group\">\n          \u003cspan className=\"sidebar-group__title\">منصات سريعة\u003c/span>\n          \u003cdiv className=\"platform-list\">\n            {platformRecords.map((platform) => (\n              (() => {\n                const PlatformIcon = platformVisuals[platform.id] ?? FolderKanban\n\n                return (\n                  \u003cbutton\n                    key={platform.id}\n                    className={\n                      platform.id === activePlatform.id\n                        ? 'platform-list__item active'\n                        : 'platform-list__item'\n                    }\n                    onClick={() => selectPlatform(platform.id)}\n                    type=\"button\"\n                  >\n                    \u003cspan className=\"platform-list__icon\">\n                      \u003cPlatformIcon size={18} />\n                    \u003c/span>\n                    \u003cspan>\n                      \u003cstrong>{platform.name}\u003c/strong>\n                      \u003cspan>{platform.segment}\u003c/span>\n                    \u003c/span>\n                  \u003c/button>\n                )\n              })()\n            ))}\n          \u003c/div>\n        \u003c/div>\n\n        \u003cdiv className=\"sidebar-footer\">\n          \u003cdiv className=\"status-pill status-live\">\n            \u003cspan className=\"status-dot\" />\n            جاهزية تشغيلية\n          \u003c/div>\n          \u003cp>التطبيق يدير الآن بيانات محلية، قوالب رسائل، ومؤشرات تحليلية لكل منصة.\u003c/p>\n        \u003c/div>\n      \u003c/aside>\n\n      \u003cdiv className=\"main-panel\">\n        \u003cheader className=\"topbar\">\n          \u003cdiv>\n            \u003cspan className=\"eyebrow\">مشروع سكاي برو للديسكتوب\u003c/span>\n            \u003ch1>مركز التحكم في سيندر برو\u003c/h1>\n            \u003cp className=\"lede\">\n              نسخة ديسكتوب عملية لإدارة المنصات والحسابات والحملات داخل تجربة\n              استخدام واضحة وسريعة وجاهزة للتطوير.\n            \u003c/p>\n          \u003c/div>\n          \u003cdiv className=\"topbar-actions\">\n            \u003cdiv className=\"status-pill status-live\">\n              \u003cspan className=\"status-dot\" />\n              الأساس التشغيلي جاهز\n            \u003c/div>\n            \u003cbutton className=\"ghost-button\" type=\"button\">\n              المرحلة الحالية: تشغيل + تحليلات\n              \u003cArrowUpRight size={16} />\n            \u003c/button>\n          \u003c/div>\n        \u003c/header>\n\n        {activeView === 'overview' && (\n          \u003cmain className=\"workspace-grid\">\n            \u003csection className=\"hero-card hero-card--wide\">\n              \u003cdiv className=\"hero-card__content\">\n                \u003cspan className=\"section-chip\">تجربة ديسكتوب شاملة\u003c/span>\n                \u003ch2>التطبيق دخل مرحلة التشغيل الفعلي داخل الواجهة\u003c/h2>\n                \u003cp>\n                  النسخة الحالية لم تعد مجرد شكل فقط، بل أصبحت تدير سجلات وحملات\n                  وحسابات محفوظة داخل التطبيق لكل منصة بشكل مستقل مع قوالب وتحليلات\n                  تشغيلية جاهزة.\n                \u003c/p>\n\n                \u003cdiv className=\"stats-grid\">\n                  {executiveStats.map((stat) => (\n                    \u003carticle className=\"stat-card\" key={stat.label}>\n                      \u003cstrong>{stat.value}\u003c/strong>\n                      \u003cspan>{stat.label}\u003c/span>\n                    \u003c/article>\n                  ))}\n                \u003c/div>\n\n                \u003cdiv className=\"highlight-grid\">\n                  {heroHighlights.map(({ icon: Icon, title, description }) => (\n                    \u003carticle className=\"highlight-card\" key={title}>\n                      \u003cdiv className=\"highlight-icon\">\n                        \u003cIcon size={18} />\n                      \u003c/div>\n                      \u003cdiv>\n                        \u003ch3>{title}\u003c/h3>\n                        \u003cp>{description}\u003c/p>\n                      \u003c/div>\n                    \u003c/article>\n                  ))}\n                \u003c/div>\n              \u003c/div>\n            \u003c/section>\n\n            \u003caside className=\"command-card\">\n              \u003cdiv className=\"command-card__header\">\n                \u003cspan className=\"section-chip subtle\">النبض التشغيلي\u003c/span>\n                \u003cSparkles size={18} />\n              \u003c/div>\n              \u003ch2>خلاصة سريعة\u003c/h2>\n              \u003cdiv className=\"roadmap-list\">\n                {overviewBoards.map(({ icon: Icon, title, value, note }) => (\n                  \u003cdiv className=\"roadmap-item\" key={item.title}>\n                    \u003cspan className=\"roadmap-index\">\n                      \u003cIcon size={12} />\n                    \u003c/span>\n                    \u003cdiv>\n                      \u003cstrong className=\"item-value\">{value}\u003c/strong>\n                      \u003cp>{title}\u003c/p>\n                      \u003csmall>{note}\u003c/small>\n                    \u003c/div>\n                  \u003c/div>\n                ))}\n              \u003c/div>\n            \u003c/aside>\n\n            \u003csection className=\"section-card section-card--full\">\n              \u003cdiv className=\"section-heading\">\n                \u003cdiv>\n                  \u003cspan className=\"section-chip subtle\">مركز الإجراءات\u003c/span>\n                  \u003ch2>ما الذي أصبح جاهزًا الآن؟\u003c/h2>\n                \u003c/div>\n              \u003c/div>\n\n              \u003cdiv className=\"actions-grid\">\n                {quickActions.map(({ title, description, icon: Icon }) => (\n                  \u003carticle className=\"action-card\" key={title}>\n                    \u003cdiv className=\"highlight-icon\">\n                      \u003cIcon size={18} />\n                    \u003c/div>\n                    \u003cdiv>\n                      \u003ch3>{title}\u003c/h3>\n                      \u003cp>{description}\u003c/p>\n                    \u003c/div>\n                  \u003c/article>\n                ))}\n              \u003c/div>\n            \u003c/section>\n\n            \u003csection className=\"pillars-card section-card--full\">\n              \u003cdiv className=\"section-heading\">\n                \u003cdiv>\n                  \u003cspan className=\"section-chip subtle\">مرتكزات المنتج\u003c/span>\n                  \u003ch2>الأعمدة الأساسية للتطوير القادم\u003c/h2>\n                \u003c/div>\n              \u003c/div>\n\n              \u003cdiv className=\"pillars-grid\">\n                {strategicPillars.map((pillar) => (\n                  \u003carticle className=\"pillar-card\" key={pillar.title}>\n                    \u003ch3>{pillar.title}\u003c/h3>\n                    \u003cp>{pillar.description}\u003c/p>\n                  \u003c/article>\n                ))}\n              \u003c/div>\n            \u003c/section>\n          \u003c/main>\n        )}\n\n        {activeView === 'platforms' && (\n          \u003cmain className=\"platform-layout\">\n            \u003csection className=\"studio-card\">\n              \u003cdiv className=\"section-heading\">\n                \u003cdiv>\n                  \u003cspan className=\"section-chip subtle\">استوديو المنصات\u003c/span>\n                  \u003ch2>لوحة تفصيلية وتشغيلية لكل منصة داخل التطبيق\u003c/h2>\n                \u003c/div>\n                \u003cdiv className=\"status-pill\">\n                  \u003cBarChart3 size={16} />\n                  بيانات فعلية محفوظة محليًا\n                \u003c/div>\n              \u003c/div>\n\n              \u003cdiv className=\"tab-strip\" role=\"tablist\" aria-label=\"منصات التواصل الاجتماعي\">\n                {platformRecords.map((platform) => {\n                  const PlatformIcon = platformVisuals[platform.id] ?? FolderKanban\n\n                  return (\n                    \u003cbutton\n                      key={platform.id}\n                      className={\n                        platform.id === activePlatform.id ? 'tab-button active' : 'tab-button'\n                      }\n                      onClick={() => selectPlatform(platform.id)}\n                      role=\"tab\"\n                      type=\"button\"\n                      aria-selected={platform.id === activePlatform.id}\n                    >\n                      \u003cspan className=\"tab-button__icon\">\n                        \u003cPlatformIcon size={16} />\n                      \u003c/span>\n                      \u003cspan className=\"tab-button__label\">{platform.name}\u003c/span>\n                      \u003csmall>{platform.segment}\u003c/small>\n                    \u003c/button>\n                  )\n                ))}\n              \u003c/div>\n\n              \u003cdiv\n                className=\"platform-focus\"\n                style={{ '--platform-theme': activePlatform.theme } as CSSProperties}\n              >\n                \u003cdiv className=\"platform-hero\">\n                  \u003cdiv>\n                    \u003cspan className=\"platform-badge\">{activePlatform.segment}\u003c/span>\n                    \u003ch3>{activePlatform.name}\u003c/h3>\n                    \u003cp className=\"platform-tagline\">{activePlatform.tagline}\u003c/p>\n                    \u003cp className=\"platform-summary\">{activePlatform.summary}\u003c/p>\n                  \u003c/div>\n                  \u003cdiv className=\"workflow-bar\">\n                    {activePlatform.workflow.map((step) => (\n                      \u003cspan key={step}>{step}\u003c/span>\n                    ))}\n                  \u003c/div>\n                \u003c/div>\n\n                \u003cdiv className=\"platform-stats\">\n                  {activePlatform.stats.map((stat) => (\n                    \u003carticle className=\"mini-stat\" key={stat.label}>\n                      \u003cstrong>{stat.value}\u003c/strong>\n                      \u003cspan>{stat.label}\u003c/span>\n                    \u003c/article>\n                  ))}\n                \u003c/div>\n              \u003c/div>\n            \u003c/section>\n\n            \u003csection className=\"section-card section-card--full\">\n              \u003cdiv className=\"section-heading\">\n                \u003cdiv>\n                  \u003cspan className=\"section-chip subtle\">حالة المنصة\u003c/span>\n                  \u003ch2>مؤشرات تشغيل {activePlatform.name}\u003c/h2>\n                \u003c/div>\n              \u003c/div>\n\n              \u003cdiv className=\"pulse-grid\">\n                {operationalPulse.map(({ icon: Icon, label, value, hint }) => (\n                  \u003carticle className=\"pulse-card\" key={item.label}>\n                    \u003cspan className=\"highlight-icon\">\n                      \u003cIcon size={16} />\n                    \u003c/span>\n                    \u003cspan>{label}\u003c/span>\n                    \u003cstrong>{value}\u003c/strong>\n                    \u003csmall>{hint}\u003c/small>\n                  \u003c/article>\n                ))}\n              \u003c/div>\n            \u003c/section>\n\n            \u003csection className=\"section-card section-card--full\">\n              \u003cdiv className=\"section-heading\">\n                \u003cdiv>\n                  \u003cspan className=\"section-chip subtle\">مكتبة القوالب\u003c/span>\n                  \u003ch2>قوالب رسائل جاهزة وقابلة لإعادة الاستخدام داخل {activePlatform.name}\u003c/h2>\n                \u003c/div>\n              \u003c/div>\n\n              \u003cdiv className=\"data-workspace\">\n                \u003carticle className=\"data-panel\">\n                  \u003cdiv className=\"subcard-heading\">\n                    \u003cMessagesSquare size={18} />\n                    \u003ch3>{editingTemplateId ? 'تعديل قالب' : 'إضافة قالب جديد'}\u003c/h3>\n                  \u003c/div>\n\n                  \u003cform className=\"editor-form\" onSubmit={handleTemplateSubmit}>\n                    \u003cdiv className=\"form-grid\">\n                      \u003clabel className=\"field\">\n                        \u003cspan>اسم القالب\u003c/span>\n                        \u003cinput\n                          value={templateDraft.title}\n                          onChange={(event) =>\n                            setTemplateDraft((current) => ({\n                              ...current,\n                              title: event.target.value,\n                            }))\n                          }\n                          placeholder=\"مثال: ترحيب بالعميل الجديد\"\n                          required\n                        />\n                      \u003c/label>\n\n                      \u003clabel className=\"field\">\n                        \u003cspan>التصنيف\u003c/span>\n                        \u003cselect\n                          value={templateDraft.category}\n                          onChange={(event) =>\n                            setTemplateDraft((current) => ({\n                              ...current,\n                              category: event.target.value as TemplateCategory,\n                            }))\n                          }\n                        >\n                          {templateCategoryOptions.map((category) => (\n                            \u003coption key={category} value={category}>\n                              {category}\n                            \u003c/option>\n                          ))}\n                        \u003c/select>\n                      \u003c/label>\n\n                      \u003clabel className=\"field field--full\">\n                        \u003cspan>نص الرسالة\u003c/span>\n                        \u003ctextarea\n                          value={templateDraft.content}\n                          onChange={(event) =>\n                            setTemplateDraft((current) => ({\n                              ...current,\n                              content: event.target.value,\n                            }))\n                          }\n                          placeholder=\"اكتب هنا الرسالة التي تريد إعادة استخدامها.\"\n                          rows={5}\n                          required\n                        />\n                      \u003c/label>\n                    \u003c/div>\n\n                    \u003cdiv className=\"button-row\">\n                      \u003cbutton className=\"primary-button\" type=\"submit\">\n                        \u003cSave size={16} />\n                        {editingTemplateId ? 'حفظ القالب' : 'إضافة القالب'}\n                      \u003c/button>\n                      \u003cbutton\n                        className=\"secondary-button\"\n                        type=\"button\"\n                        onClick={() => {\n                          setEditingTemplateId(null)\n                          setTemplateDraft(createTemplateDraft(activePlatform.id))\n                        }}\n                      >\n                        \u003cRotateCcw size={16} />\n                        إعادة تعيين\n                      \u003c/button>\n                    \u003c/div>\n                  \u003c/form>\n                \u003c/article>\n\n                \u003carticle className=\"data-panel\">\n                  \u003cdiv className=\"subcard-heading\">\n                    \u003cFileSpreadsheet size={18} />\n                    \u003ch3>القوالب النشطة\u003c/h3>\n                  \u003c/div>\n\n                  {activeTemplates.length === 0 ? (\n                    \u003cdiv className=\"empty-state\">\n                      \u003cstrong>لا توجد قوالب بعد\u003c/strong>\n                      \u003cp>أنشئ أول قالب لاستخدامه بسرعة داخل الحملات الخاصة بـ {activePlatform.name}.\u003c/p>\n                    \u003c/div>\n                  ) : (\n                    \u003cdiv className=\"records-list\">\n                      {activeTemplates.map((template) => (\n                        \u003carticle className=\"record-card\" key={template.id}>\n                          \u003cdiv className=\"record-header\">\n                            \u003cdiv>\n                              \u003ch4>{template.title}\u003c/h4>\n                              \u003cp>{template.category}\u003c/p>\n                            \u003c/div>\n                            \u003cspan className=\"tag tag--status\">{template.category}\u003c/span>\n                          \u003c/div>\n\n                          \u003cp className=\"record-notes\">{template.content}\u003c/p>\n\n                          \u003cdiv className=\"record-footer\">\n                            \u003csmall>{formatDate(template.updatedAt)}\u003c/small>\n                            \u003cdiv className=\"record-actions\">\n                              \u003cbutton\n                                className=\"icon-button\"\n                                onClick={() =>\n                                  setCampaignDraft((current) => ({\n                                    ...current,\n                                    message: template.content,\n                                    name: current.name || template.title,\n                                  }))\n                                }\n                                type=\"button\"\n                              >\n                                \u003cSparkles size={16} />\n                                تطبيق على الحملة\n                              \u003c/button>\n                              \u003cbutton\n                                className=\"icon-button\"\n                                onClick={() => {\n                                  setEditingTemplateId(template.id)\n                                  setTemplateDraft({\n                                    platformId: template.platformId,\n                                    title: template.title,\n                                    category: template.category,\n                                    content: template.content,\n                                  })\n                                }}\n                                type=\"button\"\n                              >\n                                \u003cPencilLine size={1