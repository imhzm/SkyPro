                    \u003c/label>\n                      \u003clabel className=\"field\">\n                        \u003cspan>الحالة\u003c/span>\n                        \u003cselect\n                          value={accountDraft.status}\n                          onChange={(event) =>\n                            setAccountDraft((current) => ({\n                              ...current,\n                              status: event.target.value as AccountStatus,\n                            }))\n                          }\n                        >\n                          {accountStatusOptions.map((status) => (\n                            \u003coption key={status} value={status}>\n                              {status}\n                            \u003c/option>\n                          ))}\n                        \u003c/select>\n                      \u003c/label>\n                      \u003clabel className=\"field field--full\">\n                        \u003cspan>ملاحظات\u003c/span>\n                        \u003ctextarea\n                          value={accountDraft.notes}\n                          onChange={(event) =>\n                            setAccountDraft((current) => ({\n                              ...current,\n                              notes: event.target.value,\n                            }))\n                          }\n                          placeholder=\"ملاحظات عن الحالة أو الاستخدام\"\n                          rows={3}\n                        />\n                      \u003c/label>\n                    \u003c/div>\n\n                    \u003cdiv className=\"button-row\">\n                      \u003cbutton className=\"primary-button\" type=\"submit\">\n                        \u003cPlus size={16} />\n                        إضافة حساب\n                      \u003c/button>\n                      \u003cbutton\n                        className=\"secondary-button\"\n                        type=\"button\"\n                        onClick={() => setAccountDraft(createAccountDraft(activePlatform.id))}\n                      >\n                        \u003cRotateCcw size={16} />\n                        إعادة تعيين\n                      \u003c/button>\n                    \u003c/div>\n                  \u003c/form>\n\n                  \u003cdiv className=\"records-list records-list--compact\">\n                    {activeAccounts.length === 0 ? (\n                      \u003cdiv className=\"empty-state\">\n                        \u003cstrong>لا توجد حسابات بعد\u003c/strong>\n                        \u003cp>أضف أول حساب تشغيلي للمنصة الحالية.\u003c/p>\n                      \u003c/div>\n                    ) : (\n                      activeAccounts.map((account) => (\n                        \u003carticle className=\"record-card\" key={account.id}>\n                          \u003cdiv className=\"record-header\">\n                            \u003cdiv>\n                              \u003ch4>{account.label}\u003c/h4>\n                              \u003cp>{account.username}\u003c/p>\n                            \u003c/div>\n                            \u003cspan className=\"tag tag--status\">{account.status}\u003c/span>\n                          \u003c/div>\n                          \u003cp className=\"record-notes\">{account.notes || 'بدون ملاحظات.'}\u003c/p>\n                          \u003cdiv className=\"record-footer\">\n                            \u003csmall>{formatDate(account.lastCheck)}\u003c/small>\n                            \u003cdiv className=\"record-actions\">\n                              \u003cbutton\n                                className=\"icon-button\"\n                                onClick={() =>\n                                  setAccounts((current) =>\n                                    current.map((item) =>\n                                      item.id === account.id\n                                        ? { ...item, lastCheck: new Date().toISOString() }\n                                        : item,\n                                    ),\n                                  )\n                                }\n                                type=\"button\"\n                              >\n                                \u003cActivitySquare size={16} />\n                                تحديث الفحص\n                              \u003c/button>\n                              \u003cbutton\n                                className=\"icon-button icon-button--danger\"\n                                onClick={() =>\n                                  setAccounts((current) =>\n                                    current.filter((item) => item.id !== account.id),\n                                  )\n                                }\n                                type=\"button\"\n                              >\n                                \u003cTrash2 size={16} />\n                                حذف\n                              \u003c/button>\n                            \u003c/div>\n                          \u003c/div>\n                        \u003c/article>\n                      ))\n                    )}\n                  \u003c/div>\n                \u003c/article>\n\n\n\n\n              \u003c/div>\n            \u003c/section>\n\n\n          \u003c/main>\n        )}\n\n        {activeView === 'analytics' && (\n          \u003cmain className=\"workspace-grid\">\n            \u003csection className=\"hero-card hero-card--wide\">\n              \u003cdiv className=\"hero-card__content\">\n                \u003cspan className=\"section-chip\">لوحة تحليلات تنفيذية\u003c/span>\n                \u003ch2>مؤشرات لحظية لاكتشاف النشاط والاختناقات داخل جميع المنصات\u003c/h2>\n                \u003cp>\n                  هذه الشاشة تجمع نبض التشغيل في مكان واحد: حجم السجلات، جاهزية الحملات،\n                  التقدم في المهام، وأولويات المتابعة القريبة.\n                \u003c/p>\n\n                \u003cdiv className=\"button-row analytics-actions\">\n                  \u003cbutton className=\"secondary-button\" onClick={exportAnalyticsReport} type=\"button\">\n                    \u003cDownload size={16} />\n                    تصدير تقرير Excel\n                  \u003c/button>\n                  \u003cdiv className=\"tool-hint\">\n                    \u003cFileSpreadsheet size={16} />\n                    يتضمن التقرير: نظرة عامة، أداء المنصات، والتنبيهات الحالية.\n                  \u003c/div>\n                \u003c/div>\n\n                \u003cdiv className=\"stats-grid\">\n                  \u003carticle className=\"stat-card\">\n                    \u003cstrong>{leads.length}\u003c/strong>\n                    \u003cspan>إجمالي السجلات\u003c/span>\n                  \u003c/article>\n                  \u003carticle className=\"stat-card\">\n                    \u003cstrong>{readyCampaignsCount}\u003c/strong>\n                    \u003cspan>حملات جاهزة أو نشطة\u003c/span>\n                  \u003c/article>\n\n                  \u003carticle className=\"stat-card\">\n                    \u003cstrong>{totalOperationalAssets}\u003c/strong>\n                    \u003cspan>موارد تشغيل محفوظة\u003c/span>\n                  \u003c/article>\n                \u003c/div>\n              \u003c/div>\n            \u003c/section>\n\n            \u003csection className=\"section-card\">\n              \u003cdiv className=\"section-heading\">\n                \u003cdiv>\n                  \u003cspan className=\"section-chip subtle\">قمع السجلات\u003c/span>\n                  \u003ch2>توزيع الحالات الحالية\u003c/h2>\n                \u003c/div>\n              \u003c/div>\n\n              \u003cdiv className=\"funnel-list\">\n                {leadsByStatus.map((item) => {\n                  const percentage = leads.length === 0 ? 0 : Math.round((item.count / leads.length) * 100)\n\n                  return (\n                    \u003carticle className=\"funnel-item\" key={item.status}>\n                      \u003cdiv className=\"record-header\">\n                        \u003cstrong>{item.status}\u003c/strong>\n                        \u003cspan>{item.count} سجل\u003c/span>\n                      \u003c/div>\n                      \u003cdiv className=\"analytics-progress\">\n                        \u003cspan style={{ width: `${percentage}%` }} />\n                      \u003c/div>\n                      \u003csmall>{percentage}% من إجمالي السجلات\u003c/small>\n                    \u003c/article>\n                  )\n                })}\n              \u003c/div>\n            \u003c/section>\n\n            \u003caside className=\"command-card\">\n              \u003cdiv className=\"command-card__header\">\n                \u003cspan className=\"section-chip subtle\">تنبيهات سريعة\u003c/span>\n                \u003cActivity size={18} />\n              \u003c/div>\n              \u003ch2>ما يحتاج متابعة الآن؟\u003c/h2>\n              \u003cdiv className=\"roadmap-list\">\n\n                \u003cdiv className=\"roadmap-item\">\n                  \u003cspan className=\"roadmap-index\" />\n                  \u003cdiv>\n                    \u003cstrong className=\"item-value\">{highPriorityLeads.length} عميل بأولوية عالية\u003c/strong>\n                    \u003csmall>يساعدك على معرفة أين تبدأ المتابعة اليومية.\u003c/small>\n                  \u003c/div>\n                \u003c/div>\n                \u003cdiv className=\"roadmap-item\">\n                  \u003cspan className=\"roadmap-index\" />\n                  \u003cdiv>\n                    \u003cstrong className=\"item-value\">\n                      {closedLeadsCount}/{leads.length || 0} تم إغلاقه\n                    \u003c/strong>\n                    \u003csmall>مؤشر مباشر على نسبة السجلات التي وصلت لنهاية المسار.\u003c/small>\n                  \u003c/div>\n                \u003c/div>\n              \u003c/div>\n            \u003c/aside>\n\n            \u003csection className=\"section-card section-card--full\">\n              \u003cdiv className=\"section-heading\">\n                \u003cdiv>\n                  \u003cspan className=\"section-chip subtle\">أداء المنصات\u003c/span>\n                  \u003ch2>ترتيب المنصات حسب النشاط الفعلي\u003c/h2>\n                \u003c/div>\n              \u003c/div>\n\n              \u003cdiv className=\"analytics-grid\">\n                {platformAnalytics.map((platform) => {\n                  const scoreWidth =\n                    highestPlatformScore === 0\n                      ? 0\n                      : Math.max(8, Math.round((platform.score / highestPlatformScore) * 100))\n\n                  return (\n                    \u003carticle className=\"analytics-card\" key={platform.id}>\n                      \u003cdiv className=\"record-header\">\n                        \u003cdiv>\n                          \u003ch3>{platform.name}\u003c/h3>\n                          \u003cp>{platform.segment}\u003c/p>\n                        \u003c/div>\n                        \u003cspan className=\"module-status\">نقاط {platform.score}\u003c/span>\n                      \u003c/div>\n\n                      \u003cdiv className=\"analytics-progress\">\n                        \u003cspan style={{ width: `${scoreWidth}%` }} />\n                      \u003c/div>\n\n                      \u003cdiv className=\"analytics-metrics\">\n                        \u003cdiv className=\"metric-row\">\n                          \u003cspan>السجلات\u003c/span>\n                          \u003cstrong>{platform.leadCount}\u003c/strong>\n                        \u003c/div>\n                        \u003cdiv className=\"metric-row\">\n                          \u003cspan>الحملات\u003c/span>\n                          \u003cstrong>{platform.campaignCount}\u003c/strong>\n                        \u003c/div>\n                        \u003cdiv className=\"metric-row\">\n                          \u003cspan>الحسابات\u003c/span>\n                          \u003cstrong>{platform.accountCount}\u003c/strong>\n                        \u003c/div>\n\n                      \u003c/div>\n                    \u003c/article>\n                  )\n                })}\n              \u003c/div>\n            \u003c/section>\n\n            \u003csection className=\"section-card\">\n              \u003cdiv className=\"section-heading\">\n                \u003cdiv>\n                  \u003cspan className=\"section-chip subtle\">نشاط حديث\u003c/span>\n                  \u003ch2>آخر التغييرات عبر مساحة العمل\u003c/h2>\n                \u003c/div>\n              \u003c/div>\n\n              \u003cdiv className=\"activity-list\">\n                {recentWorkspaceActivity.length === 0 ? (\n                  \u003cdiv className=\"empty-state\">\n                    \u003cstrong>لا يوجد نشاط بعد\u003c/strong>\n                    \u003cp>بمجرد إضافة بيانات أو حملات أو قوالب ستظهر هنا أحدث التحديثات.\u003c/p>\n                  \u003c/div>\n                ) : (\n                  recentWorkspaceActivity.map((item) => (\n                    \u003cdiv className=\"activity-item\" key={`${item.id}-${item.time}`}>\n                      \u003cdiv className=\"activity-dot\" />\n                      \u003cdiv>\n                        \u003cstrong>{item.title}\u003c/strong>\n                        \u003cp>{item.detail}\u003c/p>\n                        \u003csmall>{formatDate(item.time)}\u003c/small>\n                      \u003c/div>\n                    \u003c/div>\n                  ))\n                )}\n              \u003c/div>\n            \u003c/section>\n\n\n\n            \u003csection className=\"section-card\">\n              \u003cdiv className=\"section-heading\">\n                \u003cdiv>\n                  \u003cspan className=\"section-chip subtle\">عناصر حرجة\u003c/span>\n                  \u003ch2>الأولوية العالية والمهام المتأخرة\u003c/h2>\n                \u003c/div>\n              \u003c/div>\n\n              \u003cdiv className=\"alert-list\">\n                {highPriorityLeads.slice(0, 4).map((lead) => (\n                  \u003carticle className=\"alert-card\" key={lead.id}>\n                    \u003cdiv className=\"record-header\">\n                      \u003cstrong>{lead.fullName}\u003c/strong>\n                      \u003cspan>{getPlatformName(lead.platformId)}\u003c/span>\n                    \u003c/div>\n                    \u003cp>{lead.company || 'بدون شركة محددة'}\u003c/p>\n                    \u003csmall>الحالة الحالية: {lead.status}\u003c/small>\n                  \u003c/article>\n                ))}\n\n                  {highPriorityLeads.length === 0 && (\n                  \u003cdiv className=\"empty-state\">\n                    \u003cstrong>لا توجد عناصر حرجة الآن\u003c/strong>\n                    \u003cp>الوضع الحالي مستقر، ويمكنك متابعة الأداء العام من نفس الشاشة.\u003c/p>\n                  \u003c/div>\n                )}\n              \u003c/div>\n            \u003c/section>\n          \u003c/main>\n        )}\n\n\n      \u003c/div>\n    \u003c/div>\n  )\n}\n\nexport default App\n"}
              try {
                const { ErrorOverlay } = await import("/@vite/client")
