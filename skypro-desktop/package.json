{
  "name": "sender-pro-desktop",
  "private": true,
  "version": "1.31.6",
  "description": "SkyPro - تطبيق تسويق إلكتروني احترافي لأتمتة المتصفح",
  "author": "SkyPro <skywaveads@gmail.com>",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev-runner.mjs",
    "dev:renderer": "vite --host 127.0.0.1 --port 5180",
    "dev:electron": "cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5180 electron .",
    "guard:runtime-data": "node scripts/assert-clean-runtime-data.mjs",
    "prebuild:renderer": "npm run guard:runtime-data",
    "build": "npm run build:renderer",
    "build:renderer": "tsc -b && vite build",
    "bundle:chromium": "node scripts/bundle-chromium.mjs",
    "build:desktop": "npm run build:renderer && npm run bundle:chromium && electron-builder",
    "test:security": "node --test scripts/export-sanitizers.test.mjs",
    "test:bindings": "node --test scripts/verify-ipc-bindings.test.mjs",
    "test:sanitizer": "node --test scripts/test-extraction-sanitizer.test.mjs",
    "test": "npm run test:security && npm run test:bindings && npm run test:sanitizer",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource/cairo": "^5.2.7",
    "better-sqlite3": "^12.1.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.542.0",
    "nodemailer": "^8.0.5",
    "playwright": "^1.59.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.5.0",
    "simple-icons": "^16.23.0",
    "tailwind-merge": "^3.2.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.2",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.1.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4.1.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.skypro.senderpro.desktop",
    "productName": "SkyPro",
    "afterPack": "scripts/afterPack.cjs",
    "directories": {
      "output": "dist/release"
    },
    "files": [
      "dist/renderer/**/*",
      "electron/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".pw-browsers",
        "to": "pw-browsers",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/playwright/**",
      "node_modules/playwright-core/**"
    ],
    "icon": "public/icon.ico",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        "portable"
      ],
      "icon": "public/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "installerHeaderIcon": "public/icon.ico"
    },
    "publish": {
      "provider": "generic",
      "url": "https://downloads.skywaveads.com/skypro"
    }
  }
}
